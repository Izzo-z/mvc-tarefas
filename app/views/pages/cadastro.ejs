<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= tituloAba %></title>
</head>
<body>
    <h1><%= tituloPagina %></h1>

    <% if (erros && erros.length > 0) { %>
        <ul style="color: red;">
            <% erros.forEach((erro) => { %>
                <li><%= erro.msg %></li>
            <% }) %>
        </ul>
    <% } %>

    <form action="/nova-tarefa" method="post">
        <input type="hidden" name="id_tarefa" value="<%= id_tarefa %>">

        <label for="tarefa">Nome da Tarefa:</label><br>
        <textarea name="tarefa" id="tarefa"><%= tarefa.nome_tarefa %></textarea><br>

        <label for="prazo">Prazo:</label><br>
        <input type="date" name="prazo" id="prazo"
            value="<%= tarefa.prazo_tarefa ? moment(tarefa.prazo_tarefa).format('YYYY-MM-DD') : '' %>">
        <br>

        <label for="situacao">Situação:</label><br>
        <select name="situacao" id="situacao">
            <option value="0" <%= tarefa.situacao_tarefa == 0 ? 'selected' : '' %>>Cancelada</option>
            <option value="1" <%= tarefa.situacao_tarefa == 1 ? 'selected' : '' %>>Pendente</option>
            <option value="2" <%= tarefa.situacao_tarefa == 2 ? 'selected' : '' %>>Iniciada</option>
            <option value="3" <%= tarefa.situacao_tarefa == 3 ? 'selected' : '' %>>Finalizada</option>
            <option value="4" <%= tarefa.situacao_tarefa == 4 ? 'selected' : '' %>>Atrasada</option>
        </select><br><br>

        <button type="submit">Salvar</button>
        <button type="button" onclick="window.location='/'">Cancelar</button>
    </form>
</body>
</html>